# ─── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Railway: add a PostgreSQL plugin and this is set automatically
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign JWT tokens — use a long random string in production
# Generate one: openssl rand -base64 48
SESSION_SECRET=change-this-to-a-long-random-string-in-production

# Port the API server listens on (Railway injects this automatically)
PORT=8080

# ─── Optional ─────────────────────────────────────────────────────────────────

# Path where uploaded payment screenshots are stored
# On Railway: mount a persistent volume and point this to its mount path
# Example Railway volume mount: /data  →  UPLOADS_DIR=/data/uploads
UPLOADS_DIR=./uploads

# Path to the built frontend (only needed in production / Docker)
# Set automatically by railway.json start command
FRONTEND_DIST=./artifacts/marketplace/dist/public

# Node environment
NODE_ENV=production
